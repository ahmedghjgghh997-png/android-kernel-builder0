[
  {
    "kernelSource": {
      "name": "A35-KernelSU",
      "repo": "https://github.com/raspiduino/sm-a356e-kernel",
      "branch": "main",
      "device": "a35x",
      "defconfig": "exynos1380_a35x_defconfig"
    },
    "withKernelSU": true,
    "toolchains": [
      {
        "repo": "https://github.com/kdrag0n/proton-clang",
        "branch": "master",
        "name": "proton-clang",
        "binPath": ["bin"]
      }
    ],
    "params": {
      "ARCH": "arm64",
      "CC": "proton-clang/bin/clang",
      "externalCommand": {
        "CROSS_COMPILE": "proton-clang/bin/aarch64-linux-gnu-",
        "CROSS_COMPILE_ARM32": "proton-clang/bin/arm-linux-gnueabi-",
        "LD": "proton-clang/bin/ld.lld"
      }
    },
    "AnyKernel3": {
      "use": true,
      "release": true,
      "repo": "https://github.com/osm0sis/AnyKernel3",
      "branch": "master"
    }
  }
]
